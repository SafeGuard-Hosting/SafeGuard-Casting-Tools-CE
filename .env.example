# Casting Tools — Community Edition environment.
# Copy to .env and fill in. Rules:
#  - One KEY=value per line, NO trailing "# comment" after a value.
#  - Use hex/alphanumeric passwords (openssl rand -hex 24) — symbols like
#    @ : / # ? $ break the Postgres connection string.

# Postgres superuser password (the app connects as this; single-tenant).
# openssl rand -hex 24
CT_SUPER_PASSWORD=change-me-hex-24-bytes

# Session signing key. openssl rand -hex 32
CT_SESSION_SECRET=change-me-hex-32-bytes

# Public hostname you'll serve it on (used for absolute links in emails, e.g.
# self-tape / availability request links). Set this to your domain.
CT_APP_DOMAIN=casting.example.com

# CIDR(s) of your reverse proxy so forwarded client IP / proto are trusted.
# Default is loopback only; widen if your proxy runs elsewhere.
CT_TRUSTED_PROXIES=127.0.0.1/32,::1/128

# First-boot owner — created automatically so you can log straight in.
# Password needs 8+ chars with an uppercase, a digit AND a symbol.
# Leave email/password blank to use the first-run setup screen instead.
CT_INITIAL_OWNER_EMAIL=you@example.com
CT_INITIAL_OWNER_PASSWORD=Change-Me-1!
CT_INITIAL_OWNER_NAME=Owner
CT_INITIAL_COMPANY_NAME=My Workspace

# Optional: database name. New installs can leave this unset (defaults to
# "castingtools"). Only set it if you're migrating an older volume.
# CT_DB_NAME=castingtools

# Optional object storage for media + off-box backups (S3 / MinIO compatible).
# Leave blank to keep media on the local volume.
# CT_S3_ENDPOINT=
# CT_S3_BUCKET=castingtools-media
# CT_S3_ACCESS_KEY=
# CT_S3_SECRET_KEY=
# CT_S3_REGION=
